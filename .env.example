# Learning Companion — Production Configuration

# Firebase Configuration
# These can be found in your Firebase Console under Project Settings > Your Apps
FIREBASE_API_KEY=xxxxxxx...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Application Features
ENABLE_CLOUD_STORAGE=true
ENABLE_CLOUD_LOGGING=true

# Security Note: Never commit actual keys to version control.
# Use this file as a template for your local .env file.
